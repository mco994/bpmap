# Copy to .env.local and fill in. All NEXT_PUBLIC_* vars are exposed to the browser.

# Canonical site URL, used for metadata / sitemap / Open Graph.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MapLibre vector tile style. Defaults to the free, no-signup OpenFreeMap
# "positron" style if unset, so the map works out of the box.
NEXT_PUBLIC_MAP_STYLE=https://tiles.openfreemap.org/styles/positron

# Neon Postgres connection string (server-side only — NOT exposed to the
# browser). Used by `npm run db:migrate` and the ingestion scripts.
# Copy the "Pooled connection" string from the Neon console.
CONNECTION_STRING=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
